{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Daily News Brief",
  "type": "object",
  "required": ["generated_at", "timezone", "refresh_interval_hours", "stories"],
  "properties": {
    "generated_at": { "type": "string", "format": "date-time" },
    "timezone": { "const": "Asia/Kuala_Lumpur" },
    "refresh_interval_hours": { "const": 4 },
    "stories": {
      "type": "array",
      "minItems": 9,
      "items": {
        "type": "object",
        "required": [
          "id",
          "category",
          "headline",
          "summary",
          "why_it_matters",
          "published_at",
          "source_links",
          "topics",
          "importance",
          "confidence"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 3 },
          "category": {
            "enum": ["malaysia", "markets_investment", "world"]
          },
          "headline": { "type": "string", "minLength": 8 },
          "summary": { "type": "string", "minLength": 20 },
          "why_it_matters": { "type": "string", "minLength": 20 },
          "published_at": { "type": "string", "format": "date-time" },
          "source_links": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["name", "url", "publisher_type"],
              "properties": {
                "name": { "type": "string", "minLength": 2 },
                "url": {
                  "type": "string",
                  "format": "uri",
                  "pattern": "^https://"
                },
                "publisher_type": { "type": "string", "minLength": 2 }
              }
            }
          },
          "topics": {
            "type": "array",
            "items": { "type": "string" }
          },
          "importance": { "type": "integer", "minimum": 1, "maximum": 5 },
          "confidence": {
            "enum": ["verified", "cross_checked", "reported_unconfirmed"]
          }
        }
      }
    }
  }
}
