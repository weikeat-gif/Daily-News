# Optional social API credentials for scripts/fetch_social_news.py.
# Copy to .env locally or configure these in the automation environment.
# Do not put real values in Git.

# X API v2 recent search.
X_BEARER_TOKEN=
X_SOURCE_USERNAMES=bernamadotcom,BursaMalaysia,BNM_official,theedgemalaysia,Reuters,BloombergAsia
X_NEWS_QUERY=

# Facebook Graph API Page feeds. Use public Page IDs/usernames separated by commas.
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_IDS=BernamaTV,theedgemalaysia,BursaMalaysia,TheStarOnline

# Instagram Graph API hashtag recent media.
# Requires an Instagram Business/Creator account connected to a Facebook Page.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_SOURCE_ACCOUNTS=bernamaofficial,theedgemalaysia,bursamalaysia
INSTAGRAM_HASHTAGS=malaysia,bursa,ringgit,bernama,worldnews,markets

# Shared settings.
SOCIAL_TOPIC_MALAYSIA=Malaysia,BNM,Bank Negara,Bernama,Putrajaya,Anwar,MITI,DOSM,parliament,policy,subsidy
SOCIAL_TOPIC_MARKETS=Bursa,ringgit,KLSE,KLCI,IPO,earnings,dividend,investment,markets,oil,palm oil,gold,Fed,rate,inflation
SOCIAL_TOPIC_WORLD=world news,geopolitics,US,China,ASEAN,EU,war,trade,central bank,technology,AI,oil
SOCIAL_TARGET_KEYWORDS=Malaysia,Bursa,ringgit,BNM,Bank Negara,Bernama,KLSE,KLCI,investment,markets,economy,inflation,interest rate,oil,palm oil,technology,AI,geopolitics,world news
SOCIAL_EXCLUDE_KEYWORDS=giveaway,contest,promo code,voucher,sale
SOCIAL_FETCH_LIMIT=12
SOCIAL_GRAPH_VERSION=v25.0
